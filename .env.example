# Copier vers `.env` ou définir ces variables sur Vercel (projet par client).
# Voir documentation/multi-client.md

SITE_ID=sauvage-watches

# Achats en ligne (Stripe) : le front n’affiche les boutons « Acheter » que si cette valeur
# n’est pas la chaîne exacte `false` ET si `features.purchase` est true dans sites/<SITE_ID>/site.config.js
VITE_PURCHASE_ENABLED=true

# Frontend ↔ Supabase (public)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# URL du backend Express (checkout Stripe, formulaires, etc.)
# VITE_BACKEND_URL=http://localhost:3000

# URL canonique du site (optionnel ; sinon déduction VERCEL_* / site.config.js)
# VITE_BASE_URL=http://localhost:5173

# Google Analytics (optionnel)
# VITE_GA_ID=

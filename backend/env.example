# Configuration Mailjet
MAILJET_API_KEY=your_mailjet_api_key_here
MAILJET_SECRET_KEY=your_mailjet_secret_key_here

# Configuration Email
EMAIL_FROM=contact@sauvage-watches.fr

# Configuration Serveur
PORT=3000
NODE_ENV=development

# CORS production : liste d’origines séparées par des virgules (prioritaire sur les défauts Sauvage)
# BACKEND_CORS_ORIGINS=https://client.example.com,https://www.client.example.com,https://recette.client.example.com
#
# Si BACKEND_CORS_ORIGINS est vide : défaut = domaines Sauvage Watches (voir backend/server.js).

# Configuration n8n
# L'URL est automatiquement sélectionnée selon NODE_ENV:
# - Production (NODE_ENV=production): utilise /webhook/ (workflow activé)
# - Debug/Test (NODE_ENV=development ou non défini): utilise /webhook-test/
# Vous pouvez forcer une URL spécifique en définissant N8N_WORKFLOW_URL
# N8N_WORKFLOW_URL=https://n8n.srv1166238.hstgr.cloud/webhook/0adc09a6-a55c-4cd6-be94-f99c3036d441
# N8N_WORKFLOW_URL_TEST=https://n8n.srv1166238.hstgr.cloud/webhook-test/0adc09a6-a55c-4cd6-be94-f99c3036d441

# URL publique du frontend (obligatoire en prod si le domaine diffère du défaut, ex. recette)
BASE_URL=https://sauvage-watches.fr

# Configuration Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Secret pour signer les tokens d’URL d’annulation de paiement (chaîne longue aléatoire)
PAYMENT_CANCEL_SECRET=generate_a_long_random_secret
# Limite create-checkout-session par IP (fenêtre 15 min), défaut 30
# STRIPE_CHECKOUT_RATE_LIMIT_MAX=30

# Configuration Supabase (pour vérifier les montres et mettre à jour le stock)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
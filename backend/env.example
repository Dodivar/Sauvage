# =============================================================================
# Backend multi-tenant — variables d'environnement
# =============================================================================
#
# Le backend Render unique aiguille chaque requête vers la configuration du
# bon client à partir de l'Origin (ou du paramètre URL pour les webhooks Stripe).
# Tous les secrets sont préfixés `SITE_<UPPER_SITE_ID>__<KEY>`.
#
# Pour Sauvage Watches : SITE_SAUVAGE_WATCHES__*
# Pour un nouveau client (kebab-case)  : SITE_<UPPER_SNAKE_CASE>__*
#
# Rétrocompatibilité : si une variable préfixée est absente pour Sauvage,
# le serveur retombe sur la variable historique (sans préfixe) en émettant
# un warning au démarrage. Cette compat sera retirée à terme.
# =============================================================================


# -----------------------------------------------------------------------------
# Configuration serveur (globale)
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# CORS : origines additionnelles globales (CSV). Les origines déclarées dans
# `sites/<id>/site.config.js` (urls.production / urls.staging / urls.development
# + leur variante `www.`) sont déjà autorisées automatiquement.
# BACKEND_CORS_ORIGINS=https://exemple1.com,https://exemple2.com

# Site par défaut en dev quand l'Origin ne matche aucun site connu (utile pour curl).
# DEV_DEFAULT_SITE_ID=sauvage-watches


# =============================================================================
# Site : Sauvage Watches
# =============================================================================

# --- Stripe ---
SITE_SAUVAGE_WATCHES__STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
SITE_SAUVAGE_WATCHES__STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Optionnel — limite create-checkout-session par IP (fenêtre 15 min). Défaut 30.
# SITE_SAUVAGE_WATCHES__STRIPE_CHECKOUT_RATE_LIMIT_MAX=30

# --- Supabase ---
SITE_SAUVAGE_WATCHES__SUPABASE_URL=https://your-project.supabase.co
SITE_SAUVAGE_WATCHES__SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Mailjet ---
SITE_SAUVAGE_WATCHES__MAILJET_API_KEY=your_mailjet_api_key_here
SITE_SAUVAGE_WATCHES__MAILJET_SECRET_KEY=your_mailjet_secret_key_here

# --- Sécurité paiement ---
SITE_SAUVAGE_WATCHES__PAYMENT_CANCEL_SECRET=generate_a_long_random_secret

# Optionnel — override du BASE_URL frontend (sinon urls.production du manifest).
# SITE_SAUVAGE_WATCHES__BASE_URL=https://sauvage-watches.fr

# Optionnel — override de l'adresse `From` Mailjet (sinon site.config.backend.email.fromAddress).
# SITE_SAUVAGE_WATCHES__EMAIL_FROM=contact@sauvage-watches.fr


# =============================================================================
# Site : Demo Store (modèle pour ajouter un nouveau client)
# =============================================================================
# SITE_DEMO_STORE__STRIPE_SECRET_KEY=sk_...
# SITE_DEMO_STORE__STRIPE_WEBHOOK_SECRET=whsec_...
# SITE_DEMO_STORE__SUPABASE_URL=https://...supabase.co
# SITE_DEMO_STORE__SUPABASE_SERVICE_ROLE_KEY=...
# SITE_DEMO_STORE__MAILJET_API_KEY=...
# SITE_DEMO_STORE__MAILJET_SECRET_KEY=...
# SITE_DEMO_STORE__PAYMENT_CANCEL_SECRET=...


# =============================================================================
# Variables historiques (LEGACY — Sauvage uniquement, à migrer)
# =============================================================================
# Tant que `SITE_SAUVAGE_WATCHES__*` n'est pas défini, ces variables servent
# de fallback pour le site `sauvage-watches`. À supprimer après migration.
#
# MAILJET_API_KEY=
# MAILJET_SECRET_KEY=
# EMAIL_FROM=contact@sauvage-watches.fr
# BASE_URL=https://sauvage-watches.fr
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYMENT_CANCEL_SECRET=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# N8N_WORKFLOW_URL=
